# Keep project-local Spec Kit skills, ignore any other agent-local state.
.agents/*
!.agents/skills/
!.agents/skills/**

# GCP / Firebase service account keys — never commit these
*service-account*.json
*service_account*.json
*-key.json
*credentials*.json

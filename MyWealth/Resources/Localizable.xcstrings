    },
    "Get gentle reminders to keep your portfolio updated and review your wealth regularly." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احصل على تذكيرات لطيفة لتحديث محفظتك ومراجعة ثروتك بانتظام."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erhalten Sie sanfte Erinnerungen, um Ihr Portfolio auf dem neuesten Stand zu halten und Ihr Vermögen regelmäßig zu überprüfen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reciba recordatorios amables para mantener su cartera actualizada y revisar su patrimonio con regularidad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recevez des rappels doux pour garder votre portefeuille à jour et révisez régulièrement votre patrimoine."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने पोर्टफोलियो को अद्यतन रखने और नियमित रूप से अपनी संपत्ति की समीक्षा करने के लिए सौम्य अनुस्मारक प्राप्त करें।"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Receba lembretes gentis para manter seu portfólio atualizado e revisar seu patrimônio regularmente."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "获得温和的提醒，以更新您的投资组合并定期查看您的财富。"
          }
        }
      }
    },

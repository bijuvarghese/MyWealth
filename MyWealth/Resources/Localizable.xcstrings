    "Enter a positive target amount, supported currency, and valid target date.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक सकारात्मक लक्ष्य राशि, समर्थित मुद्रा और वैध लक्ष्य तिथि दर्ज करें।"
          }
        },
        "es": {

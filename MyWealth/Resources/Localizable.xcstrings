    "Assets and liabilities can still use other currencies; totals are converted back here when rates are available." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا يزال من الممكن استخدام الأصول والالتزامات بعملات أخرى؛ يتم تحويل الإجماليات مرة أخرى هنا عندما تكون الأسعار متاحة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vermögenswerte und Verbindlichkeiten können weiterhin andere Währungen verwenden; Die Summen werden hier wieder umgerechnet, sobald Kurse verfügbar sind."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los activos y pasivos aún pueden utilizar otras monedas; los totales se vuelven a convertir aquí cuando las tarifas están disponibles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les actifs et passifs peuvent toujours utiliser d'autres devises ; les totaux sont reconvertis ici lorsque les tarifs sont disponibles."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "संपत्ति और देनदारियां अभी भी अन्य मुद्राओं का उपयोग कर सकती हैं; दरें उपलब्ध होने पर कुल योग को यहां वापस परिवर्तित कर दिया जाता है।"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ativos e passivos ainda podem usar outras moedas; os totais são convertidos aqui quando as taxas estão disponíveis."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "资产和负债仍可以使用其他货币；当费率可用时，总计将转换回此处。"
          }
        }
      }
    },

    "Average net worth increase needed if progress is spread evenly to the target date." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يلزم زيادة متوسط ​​القيمة الصافية إذا تم توزيع التقدم بالتساوي على التاريخ المستهدف."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durchschnittliche Nettovermögenssteigerung erforderlich, wenn der Fortschritt gleichmäßig bis zum Zieldatum verteilt ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se necesita un aumento promedio del patrimonio neto si el progreso se distribuye uniformemente hasta la fecha objetivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Augmentation de la valeur nette moyenne nécessaire si les progrès sont répartis uniformément jusqu'à la date cible."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि प्रगति लक्ष्य तिथि तक समान रूप से फैली हुई है तो औसत निवल मूल्य में वृद्धि की आवश्यकता है।"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O aumento médio do patrimônio líquido é necessário se o progresso for distribuído uniformemente até a data prevista."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果进展均匀地分布到目标日期，则需要平均净资产增长。"
          }
        }
      }
    },

    "What one extra year of saving and growth is worth in real spending power.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बचत और वृद्धि का एक अतिरिक्त वर्ष वास्तविक खर्च करने की क्षमता के लिए कितना मूल्यवान है।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo que vale un año más de ahorro y crecimiento en poder adquisitivo real."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanto vale um ano extra de poupança e crescimento em poder de compra real."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Que vaut une année supplémentaire d'épargne et de croissance en pouvoir d'achat réel."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was ein zusätzliches Jahr des Sparens und Wachstums an echter Kaufkraft wert ist."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "额外一年的储蓄和增长对于实际消费能力来说是值得的。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ما قيمة سنة إضافية من الادخار والنمو من حيث القدرة الشرائية الحقيقية."
          }
        }
      }
    },

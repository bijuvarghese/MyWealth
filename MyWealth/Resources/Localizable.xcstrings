    "Projections are indicative and use your recorded net worth history. They are not financial advice or a guarantee.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अनुमान सांकेतिक हैं और आपके रिकॉर्ड किए गए निवल मूल्य इतिहास का उपयोग करते हैं। वे वित्तीय सलाह या गारंटी नहीं हैं।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las proyecciones son indicativas y utilizan su historial de patrimonio neto registrado. No son un asesoramiento financiero ni una garantía."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As projeções são indicativas e utilizam seu histórico de patrimônio líquido registrado. Eles não são conselhos financeiros ou garantias."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les projections sont indicatives et utilisent l'historique de votre valeur nette enregistrée. Ce ne sont pas des conseils financiers ni une garantie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prognosen sind indikativ und basieren auf Ihrer aufgezeichneten Vermögenshistorie. Sie stellen keine Finanzberatung oder Garantie dar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "预测仅供参考，并使用您记录的净资产历史记录。它们不是财务建议或保证。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التوقعات إرشادية وتستخدم تاريخ صافي ثروتك المسجل. فهي ليست نصيحة مالية أو ضمانة."
          }
        }
      }
    },
    "Pull to refresh or check back later": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ताज़ा करने के लिए खींचें या बाद में दोबारा जांचें"
          }
        },

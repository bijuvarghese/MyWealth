        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "रिकॉर्ड किए गए इतिहास में निवल संपत्ति में %@ की कमी आई।"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O patrimônio líquido diminuiu em %@ ao longo do histórico registrado."

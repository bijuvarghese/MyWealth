    "Portfolio spans %lld categories — well diversified.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पोर्टफोलियो %lld श्रेणियों तक फैला हुआ है - अच्छी तरह से विविध।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cartera abarca categorías %lld, bien diversificada."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O portfólio abrange categorias %lld – bem diversificado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le portefeuille couvre les catégories %lld — bien diversifié."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Portfolio umfasst %lld-Kategorien – gut diversifiziert."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "投资组合涵盖 %lld 类别 — 多元化。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تشمل المحفظة فئات %lld - متنوعة بشكل جيد."
          }
        }
      }
    },
    "All assets are in one category. Adding more categories reduces risk.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सभी संपत्तियां एक श्रेणी में हैं। अधिक श्रेणियाँ जोड़ने से जोखिम कम हो जाता है।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos los activos están en una categoría. Agregar más categorías reduce el riesgo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os ativos estão em uma categoria. Adicionar mais categorias reduz o risco."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous les actifs sont dans une seule catégorie. L'ajout de catégories supplémentaires réduit les risques."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Vermögenswerte gehören zu einer Kategorie. Das Hinzufügen weiterer Kategorien verringert das Risiko."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有资产都属于一个类别。添加更多类别可以降低风险。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جميع الأصول في فئة واحدة. إضافة المزيد من الفئات يقلل من المخاطر."
          }
        }
      }
    },

    "Net worth decreased by %@ over recorded history." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انخفض صافي القيمة بمقدار %@ على مدار التاريخ المسجل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Nettovermögen ist im Verlauf der Aufzeichnungen um %@ gesunken."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El patrimonio neto disminuyó en %@ durante la historia registrada."

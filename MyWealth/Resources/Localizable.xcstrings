    "Portfolio health is %@ at %lld/100, with %@ in tracked assets and %@. Allocation is currently led by %@. %@" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "صحة المحفظة هي %1$@ عند %2$lld/100، مع %3$@ في الأصول المتعقبة و%4$@. تتم إدارة التخصيص حاليًا بواسطة %5$@. %6$@"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Zustand des Portfolios beträgt %1$@ bei %2$lld/100, mit %3$@ in den verfolgten Vermögenswerten und %4$@. Die Allokation wird derzeit von %5$@ geleitet. %6$@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El estado de la cartera es %1$@ en %2$lld/100, con %3$@ en activos rastreados y %4$@. Actualmente, la asignación está dirigida por %5$@. %6$@"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La santé du portefeuille est %1$@ à %2$lld/100, avec %3$@ dans les actifs suivis et %4$@. L'allocation est actuellement dirigée par %5$@. %6$@"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "पोर्टफोलियो स्वास्थ्य %2$lld/100 पर %1$@ है, ट्रैक की गई संपत्तियों में %3$@ और %4$@ है। आवंटन का नेतृत्व वर्तमान में %5$@ द्वारा किया जाता है। %6$@"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A integridade do portfólio é %1$@ em %2$lld/100, com %3$@ em ativos rastreados e %4$@. A alocação é atualmente liderada por %5$@. %6$@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "投资组合健康状况为 %1$@，为 %2$lld/100，跟踪资产为 %3$@，%4$@。目前分配由%5$@主导。 %6$@"
          }
        }
      }
    },

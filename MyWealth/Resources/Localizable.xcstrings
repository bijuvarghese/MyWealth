    "Cash & deposits are under 5% of assets. A small buffer helps cover liabilities." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "النقد والودائع أقل من 5% من الأصول. يساعد المخزن المؤقت الصغير على تغطية الالتزامات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",

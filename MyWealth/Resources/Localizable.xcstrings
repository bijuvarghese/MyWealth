    "Enable notifications in Settings to receive reminders about your portfolio." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتمكين الإشعارات في الإعدادات لتلقي تذكيرات حول محفظتك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivieren Sie Benachrichtigungen in den Einstellungen, um Erinnerungen zu Ihrem Portfolio zu erhalten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habilite las notificaciones en Configuración para recibir recordatorios sobre su cartera."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activez les notifications dans Paramètres pour recevoir des rappels concernant votre portefeuille."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने पोर्टफोलियो के बारे में अनुस्मारक प्राप्त करने के लिए सेटिंग्स में सूचनाएं सक्षम करें।"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ative notificações em Configurações para receber lembretes sobre seu portfólio."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在“设置”中启用通知以接收有关您的投资组合的提醒。"
          }
        }
      }
    },

    },
    "This backup contains a different goal. Other backup records remain additive.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस बैकअप में एक अलग लक्ष्य है। अन्य बैकअप रिकॉर्ड योगात्मक बने रहते हैं।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta copia de seguridad contiene un objetivo diferente. Otros registros de respaldo siguen siendo acumulativos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este backup contém um objetivo diferente. Outros registros de backup permanecem aditivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette sauvegarde contient un objectif différent. Les autres enregistrements de sauvegarde restent additifs."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Backup enthält ein anderes Ziel. Andere Sicherungsdatensätze bleiben additiv."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该备份包含不同的目标。其他备份记录仍然是附加的。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحتوي هذه النسخة الاحتياطية على هدف مختلف. تظل سجلات النسخ الاحتياطي الأخرى إضافية."
          }
        }
      }
    },
    "This removes only your goal. Assets, liabilities, and history stay unchanged.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह केवल आपके लक्ष्य को हटाता है। संपत्ति, देनदारियां और इतिहास अपरिवर्तित रहते हैं।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina solo tu objetivo. Los activos, los pasivos y el historial permanecen sin cambios."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso remove apenas o seu objetivo. Ativos, passivos e histórico permanecem inalterados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime uniquement votre objectif. L'actif, le passif et l'historique restent inchangés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch wird nur Ihr Ziel entfernt. Vermögenswerte, Verbindlichkeiten und Historie bleiben unverändert."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这只会删除您的目标。资产、负债和历史记录保持不变。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يؤدي هذا إلى إزالة هدفك فقط. الأصول والالتزامات والتاريخ تبقى دون تغيير."
          }
        }
      }
    },
    "This removes the asset from your current portfolio. Existing history snapshots are kept.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह आपके वर्तमान पोर्टफोलियो से संपत्ति को हटा देता है। मौजूदा इतिहास के स्नैपशॉट रखे गए हैं।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina el activo de su cartera actual. Se conservan las instantáneas del historial existente."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso remove o ativo do seu portfólio atual. Os instantâneos do histórico existente são mantidos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime l'actif de votre portefeuille actuel. Les instantanés d’historique existants sont conservés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch wird der Vermögenswert aus Ihrem aktuellen Portfolio entfernt. Vorhandene Verlaufs-Snapshots bleiben erhalten."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",

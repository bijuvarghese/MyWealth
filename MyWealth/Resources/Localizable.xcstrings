    "Income and spend are entered in %@, then converted for each country. Clear spend to use the currency-country baseline.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आय और व्यय को %@ में दर्ज किया जाता है, फिर प्रत्येक देश के लिए परिवर्तित किया जाता है। मुद्रा-देश आधार रेखा का उपयोग करने के लिए स्पष्ट व्यय।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los ingresos y gastos se ingresan en %@ y luego se convierten para cada país. Borre el gasto para utilizar la línea base moneda-país."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As receitas e despesas são inseridas em %@ e depois convertidas para cada país. Limpe os gastos para usar a linha de base do país-moeda."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les revenus et dépenses sont saisis dans %@, puis convertis pour chaque pays. Effacez les dépenses pour utiliser la référence devise-pays."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einnahmen und Ausgaben werden in %@ eingegeben und dann für jedes Land umgerechnet. Löschen Sie die Ausgaben, um die Währung-Land-Basislinie zu verwenden."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收入和支出输入 %@，然后针对每个国家/地区进行转换。明确支出以使用货币国家基准。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم إدخال الدخل والإنفاق في %@، ثم يتم تحويلهما لكل بلد. قم بمسح الإنفاق لاستخدام خط الأساس الخاص ببلد العملة."
          }
        }
      }
    },

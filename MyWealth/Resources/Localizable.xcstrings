    "Turn on iCloud only if you want Apple iCloud backup and sync through your personal account.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud को केवल तभी चालू करें जब आप Apple iCloud बैकअप और अपने व्यक्तिगत खाते के माध्यम से सिंक करना चाहते हों।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Active iCloud solo si desea realizar una copia de seguridad y sincronización de Apple iCloud a través de su cuenta personal."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative o iCloud apenas se desejar fazer backup do Apple iCloud e sincronizar através de sua conta pessoal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez iCloud uniquement si vous souhaitez sauvegarder et synchroniser Apple iCloud via votre compte personnel."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie iCloud nur, wenn Sie eine Apple iCloud-Sicherung und -Synchronisierung über Ihr persönliches Konto wünschen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅当您希望通过个人帐户进行 Apple iCloud 备份和同步时才打开 iCloud。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتشغيل iCloud فقط إذا كنت تريد النسخ الاحتياطي والمزامنة لـ Apple iCloud من خلال حسابك الشخصي."
          }
        }
      }

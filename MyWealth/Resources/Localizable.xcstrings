    "Spending %@/yr - cutting expenses shrinks both your target and the time it takes to get there.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@/वर्ष खर्च करना - खर्चों में कटौती से आपका लक्ष्य और उस तक पहुंचने में लगने वाला समय दोनों कम हो जाता है।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gastar %@/año: recortar gastos reduce tanto su objetivo como el tiempo que lleva llegar allí."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Gastar %@/ano - cortar despesas reduz sua meta e o tempo que leva para alcançá-la."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dépenses %@/an : réduire les dépenses réduit à la fois votre objectif et le temps nécessaire pour y parvenir."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausgaben %@/Jahr – durch Ausgabenkürzungen schrumpfen sowohl Ihr Ziel als auch die Zeit, die Sie benötigen, um dieses Ziel zu erreichen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "支出 %@/年 - 削减开支会缩短您的目标和实现目标所需的时间。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إنفاق %@/سنة - يؤدي خفض النفقات إلى تقليص هدفك والوقت الذي تستغرقه للوصول إلى هناك."
          }
        }
      }
    },

    "Amount is stored in troy oz. Estimated value uses live metal prices (USD).": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "राशि ट्रॉय ओज़ में संग्रहीत है। अनुमानित मूल्य जीवित धातु की कीमतों (यूएसडी) का उपयोग करता है।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cantidad se almacena en onzas troy. El valor estimado utiliza los precios de los metales vivos (USD)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O valor é armazenado em onças troy. O valor estimado usa preços de metais vivos (USD)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le montant est stocké en onces troy. La valeur estimée utilise les prix actuels des métaux (USD)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Menge wird in Feinunzen gespeichert. Der geschätzte Wert basiert auf Live-Metallpreisen (USD)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "金额以金衡盎司存储。估算值使用实时金属价格（美元）。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الكمية مخزنة بالأوقية التروي. تستخدم القيمة المقدرة أسعار المعادن الحية (بالدولار الأمريكي)."
          }
        }
      }
    },

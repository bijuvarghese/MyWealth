    "Choose the currencies you want to see on totals, rates, widgets, and net worth views.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वे मुद्राएँ चुनें जिन्हें आप कुल, दरों, विजेट्स और निवल मूल्य दृश्यों पर देखना चाहते हैं।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija las monedas que desea ver en totales, tasas, widgets y vistas de patrimonio neto."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha as moedas que deseja ver nos totais, taxas, widgets e visualizações de patrimônio líquido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez les devises que vous souhaitez voir sur les totaux, les taux, les widgets et les vues de la valeur nette."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie die Währungen aus, die Sie in Summen, Kursen, Widgets und Vermögensansichten sehen möchten."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择您想要在总计、汇率、小部件和净值视图中查看的货币。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر العملات التي تريد رؤيتها في الإجماليات والأسعار والأدوات وطرق عرض القيمة الصافية."
          }
        }
      }
    },

    "Get AI insights inside Wealth Map" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "احصل على رؤى الذكاء الاصطناعي داخل Wealth Map"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erhalten Sie KI-Einblicke in Wealth Map"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obtenga información sobre inteligencia artificial dentro de Wealth Map"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obtenez des informations sur l'IA dans Wealth Map"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wealth Map के अंदर AI अंतर्दृष्टि प्राप्त करें"
          }
        },
        "pt-BR" : {
          "stringUnit" : {

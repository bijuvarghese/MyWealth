            "value": "Wealth Map"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map"
          }
        }
      }
    },
    "Wealth Map does not require a separate account or bank login, and you can change this anytime in Settings.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map के लिए अलग खाते या बैंक लॉगिन की आवश्यकता नहीं है, और आप इसे सेटिंग्स में कभी भी बदल सकते हैं।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map no requiere una cuenta separada ni un inicio de sesión bancario, y puede cambiar esto en cualquier momento en Configuración."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map não requer uma conta separada ou login bancário, e você pode alterar isso a qualquer momento em Configurações."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map ne nécessite pas de compte ou de connexion bancaire distinct, et vous pouvez modifier cela à tout moment dans les paramètres."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für Wealth Map ist kein separates Konto oder Bank-Login erforderlich, und Sie können dies jederzeit in den Einstellungen ändern."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map 不需要单独的帐户或银行登录，您可以随时在“设置”中更改此设置。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يتطلب Wealth Map حسابًا منفصلاً أو تسجيل دخول مصرفيًا، ويمكنك تغيير ذلك في أي وقت في الإعدادات."
          }
        }
      }
    },
    "Wealth Map keeps records on this device unless you enable iCloud sync or export a backup.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map इस डिवाइस पर रिकॉर्ड रखता है जब तक कि आप iCloud सिंक सक्षम नहीं करते या बैकअप निर्यात नहीं करते।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map mantiene registros en este dispositivo a menos que habilite la sincronización de iCloud o exporte una copia de seguridad."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map mantém registros neste dispositivo, a menos que você ative a sincronização do iCloud ou exporte um backup."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map conserve des enregistrements sur cet appareil, sauf si vous activez la synchronisation iCloud ou exportez une sauvegarde."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map speichert Aufzeichnungen auf diesem Gerät, es sei denn, Sie aktivieren die iCloud-Synchronisierung oder exportieren ein Backup."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map 会在此设备上保留记录，除非您启用 iCloud 同步或导出备份。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتفظ Wealth Map بالسجلات على هذا الجهاز ما لم تقم بتمكين مزامنة iCloud أو تصدير نسخة احتياطية."
          }
        }
      }
    },
    "Wealth Map keeps your financial records on this device by default.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map आपके वित्तीय रिकॉर्ड को डिफ़ॉल्ट रूप से इस डिवाइस पर रखता है।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map mantiene sus registros financieros en este dispositivo de forma predeterminada."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map mantém seus registros financeiros neste dispositivo por padrão."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map conserve vos dossiers financiers sur cet appareil par défaut."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map speichert Ihre Finanzunterlagen standardmäßig auf diesem Gerät."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map 默认在此设备上保存您的财务记录。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتفظ Wealth Map بسجلاتك المالية على هذا الجهاز بشكل افتراضي."
          }
        }
      }
    },
    "Wealth Map uses this currency as the anchor for your private net worth view.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map इस मुद्रा का उपयोग आपके निजी नेटवर्थ दृश्य के लिए एंकर के रूप में करता है।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map utiliza esta moneda como ancla para su vista de patrimonio neto privado."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map usa esta moeda como âncora para sua visão de patrimônio líquido privado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map utilise cette devise comme point d'ancrage pour votre vue de valeur nette privée."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map verwendet diese Währung als Anker für Ihre private Vermögensansicht."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Wealth Map 使用该货币作为您私人净值视图的锚点。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تستخدم Wealth Map هذه العملة كمرتكز لعرض صافي ثروتك الخاصة."
          }
        }
      }
    },

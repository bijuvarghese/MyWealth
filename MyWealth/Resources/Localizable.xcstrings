        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह आपके वर्तमान पोर्टफोलियो से संपत्ति को हटा देता है। मौजूदा इतिहास के स्नैपशॉट रखे गए हैं।"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",

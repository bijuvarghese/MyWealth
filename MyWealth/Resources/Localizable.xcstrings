    "Real return after inflation. 7% is the long-term stock market average.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मुद्रास्फीति के बाद वास्तविक रिटर्न। 7% दीर्घकालिक शेयर बाज़ार का औसत है।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",

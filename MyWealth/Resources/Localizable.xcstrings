    "Cash & deposits are under 5% of assets. A small buffer helps cover liabilities.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नकद और जमा संपत्ति के 5% से कम हैं। एक छोटा बफर देनदारियों को कवर करने में मदद करता है।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El efectivo y los depósitos están por debajo del 5% de los activos. Un pequeño colchón ayuda a cubrir los pasivos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dinheiro e depósitos representam menos de 5% dos ativos. Um pequeno buffer ajuda a cobrir passivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les liquidités et les dépôts représentent moins de 5 % des actifs. Un petit tampon permet de couvrir les dettes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bargeld und Einlagen machen weniger als 5 % des Vermögens aus. Ein kleiner Puffer hilft, Verbindlichkeiten abzudecken."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "现金和存款占资产的比例低于5%。较小的缓冲有助于弥补负债。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "النقد والودائع أقل من 5% من الأصول. يساعد المخزن المؤقت الصغير على تغطية الالتزامات."
          }
        }
      }
    },
    "Milestone reached! Net worth crossed %@.": {

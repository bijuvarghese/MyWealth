    "Your base currency is always included, and you can reorder the rest anytime.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी आधार मुद्रा हमेशा शामिल रहती है, और आप शेष मुद्रा को किसी भी समय पुनः व्यवस्थित कर सकते हैं।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Su moneda base siempre está incluida y puede reordenar el resto en cualquier momento."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua moeda base está sempre incluída e você pode reordenar o restante a qualquer momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre devise de base est toujours incluse et vous pouvez réorganiser le reste à tout moment."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Basiswährung ist immer enthalten und Sie können den Rest jederzeit nachbestellen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "始终包含您的基础货币，您可以随时重新订购其余货币。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم تضمين عملتك الأساسية دائمًا، ويمكنك إعادة طلب الباقي في أي وقت."
          }
        }
      }
    },

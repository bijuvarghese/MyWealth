    "Value changes will appear here after this asset is updated.": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस संपत्ति के अद्यतन होने के बाद मूल्य परिवर्तन यहां दिखाई देंगे।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los cambios de valor aparecerán aquí después de que se actualice este recurso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As alterações de valor aparecerão aqui após a atualização deste ativo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les modifications de valeur apparaîtront ici après la mise à jour de cet actif."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wertänderungen werden hier angezeigt, nachdem dieses Asset aktualisiert wurde."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此资产更新后，值更改将显示在此处。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستظهر تغييرات القيمة هنا بعد تحديث هذا الأصل."
          }
        }
      }
    },

    "Model your financial independence target and timeline": {
      "localizations": {
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने वित्तीय स्वतंत्रता लक्ष्य और समयरेखा को मॉडल करें"
          }
        },
        "es": {
          "stringUnit": {
